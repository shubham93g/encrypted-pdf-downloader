# Email address that sends the PDFs
SENDER_EMAIL=sender@example.com

# Keyword that must appear anywhere in the subject line (case-insensitive)
SUBJECT_KEYWORD=

# Comma-separated list of passwords to try when decrypting PDF attachments (omit or leave blank if PDFs are not encrypted)
PDF_PASSWORDS=password1,password2

# Directory where decrypted PDFs will be saved (relative or absolute path)
OUTPUT_DIR=./pdfs

# Maximum number of recent PDFs to download
MAX_PDFS=6

# Set to true to overwrite existing files instead of appending a suffix (e.g. "(2)")
OVERWRITE_FILES=false

# Logging verbosity: DEBUG, INFO, WARNING, ERROR (default: INFO)
# LOG_LEVEL=INFO
