# Email address that sends payslips
SENDER_EMAIL=payroll@example.com

# Keyword to match in the email subject line
SUBJECT_KEYWORD=payslip

# Password used to decrypt the PDF attachments
PDF_PASSWORD=your_pdf_password

# Directory where decrypted PDFs will be saved (relative or absolute path)
OUTPUT_DIR=./payslips

# Maximum number of recent payslips to download
MAX_PAYSLIPS=6
